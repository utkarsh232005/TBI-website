# ==============================================================================
# FIREBASE CLIENT SDK
# These variables are exposed to the browser to initialize the Firebase Client SDK.
# ==============================================================================
NEXT_PUBLIC_FIREBASE_API_KEY="your-client-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="your-measurement-id" # Optional

# ==============================================================================
# FIREBASE ADMIN SDK
# Used securely on the server-side to bypass security rules for admin operations.
# Note: These match the variable names used in src/lib/firebase-admin.ts
# ==============================================================================
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
# For the private key, you can provide it with real newlines wrapped in quotes 
# or mapped to \n which is then parsed by the code.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-contents\n-----END PRIVATE KEY-----\n"

# ==============================================================================
# AI & GENKIT 
# ==============================================================================
# Required by @genkit-ai/googleai for Gemini features
GEMINI_API_KEY="your-gemini-api-key"

# ==============================================================================
# OTHER SERVICES (Found in Codebase)
# ==============================================================================
# Resend for emailing flows
RESEND_API_KEY="re_your_resend_api_key_here"
RESEND_FROM_EMAIL="TBI Platform <onboarding@resend.dev>" # Optional

# Used for Google Drive integrations / Admin tasks
GOOGLE_SERVICE_ACCOUNT_KEY_JSON='{"type":"service_account",...}'

# Application URL used for generating email links
NEXT_PUBLIC_APP_URL="http://localhost:9002"
